{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "toptopduck",
  "version": "0.1.0",
  "identifier": "dev.toptopduck.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      { "label": "main", "title": "toptopduck", "width": 1024, "height": 768 }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
