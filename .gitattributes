# Normalize line endings: text files are stored as LF in the repo and checked
# out as LF on every platform. This overrides core.autocrlf, so Windows clones
# no longer get CRLF working trees (which previously made prettier/eslint and
# cross-platform diffs noisy).
* text=auto eol=lf

# Source — explicit, in case auto-detection ever wavers.
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.rs    text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.json  text eol=lf
*.toml  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.md    text eol=lf
*.lock  text eol=lf
*.sh    text eol=lf

# Binary assets — never normalize, never diff as text.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.ico   binary
*.icns  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.eot   binary
*.xlsx  binary
*.xls   binary
*.dll   binary
*.exe   binary
*.lib   binary
*.so    binary
*.dylib binary
*.pdb   binary
